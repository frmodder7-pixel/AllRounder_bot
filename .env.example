# Copy this file to ".env" for LOCAL testing only.
# On Railway/Render, set these in the service dashboard variables.

# REQUIRED — get it from @BotFather (/newbot)
BOT_TOKEN=123456:ABC-your-token-here

# Your Telegram numeric id (send /id to the bot). Enables /stats and /broadcast.
OWNER_ID=0

# OPTIONAL — free key from https://aistudio.google.com/app/apikey
# Set it to give the bot an AI brain (replies in Hinglish).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation
GEMINI_IMAGE_FALLBACK_MODELS=gemini-2.5-flash-image,imagen-4.0-generate-001
GEMINI_FALLBACK_MODELS=gemini-1.5-flash

# OPTIONAL — free key from https://cricketdata.org for live /cricket scores.
CRICKET_API_KEY=

# OPTIONAL — PostgreSQL connection string for PERMANENT storage.
# On Railway: add a Postgres database, then set this to ${{ Postgres.DATABASE_URL }}.
# If left empty, the bot uses a local SQLite file (data resets on redeploy).
DATABASE_URL=

# How many warns before auto-ban (default 3)
WARN_LIMIT=3
